generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AccountingAccount {
  id          String              @id @default(cuid())
  tenantId    String
  code        String
  name        String
  level       AccountLevel
  nature      AccountNature
  isActive    Boolean             @default(true)
  parentId    String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  account     AccountingAccount?  @relation("AccountingAccountToAccountingAccount", fields: [parentId], references: [id])
  children    AccountingAccount[] @relation("AccountingAccountToAccountingAccount")
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  BillingItem BillingItem[]
  lines       TransactionLine[]

  @@unique([tenantId, code])
}

model AccountingThirdParty {
  id               String            @id @default(cuid())
  tenantId         String
  documentType     String
  documentNumber   String
  name             String
  email            String?
  phone            String?
  userId           String?           @unique
  providerId       String?           @unique
  taxLevelCode     String?
  ciiuCode         String?
  municipalityCode String?
  postalCode       String?
  createdAt        DateTime          @default(now())
  provider         Provider?         @relation(fields: [providerId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User?             @relation(fields: [userId], references: [id])
  Invoice          Invoice[]
  lines            TransactionLine[]

  @@unique([tenantId, documentType, documentNumber])
}

model BillingItem {
  id          String            @id @default(cuid())
  tenantId    String
  code        String
  name        String
  basePrice   Decimal?
  taxRate     Decimal           @default(0)
  accountId   String
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  account     AccountingAccount @relation(fields: [accountId], references: [id])
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  InvoiceLine InvoiceLine[]

  @@unique([tenantId, code])
}

model BrandBrain {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  tone          String   @default("PROFESSIONAL")
  policies      String?
  faq           Json?
  responseRules String?
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ContractRequest {
  id               String         @id @default(cuid())
  tenantId         String
  prospectId       String
  propertyId       String
  status           ContractStatus @default(PENDING_AI)
  formData         Json?
  aiDraft          String?
  approvedByUserId String?
  rejectionReason  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User?          @relation(fields: [approvedByUserId], references: [id])
  property         Property       @relation(fields: [propertyId], references: [id])
  prospect         Prospect       @relation(fields: [prospectId], references: [id])
}

model DianResolution {
  id               String   @id @default(cuid())
  tenantId         String
  prefix           String
  resolutionNumber String
  startNumber      Int
  endNumber        Int
  currentNumber    Int
  validFrom        DateTime
  validTo          DateTime
  technicalKey     String?
  softwareId       String?
  softwarePin      String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model DigitalCertificate {
  id           String    @id @default(cuid())
  tenantId     String    @unique
  filePath     String    @default("")
  fileBuffer   Bytes?
  passwordHash String
  validUntil   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model InventoryEvidence {
  id                 String              @id @default(cuid())
  inventoryItemId    String
  evidenceType       EvidenceType
  url                String
  aiAnalysisStatus   AIAnalysisStatus    @default(PENDING)
  aiComparisonResult AIComparisonResult?
  captureDate        DateTime            @default(now())
  InventoryItem      InventoryItem       @relation(fields: [inventoryItemId], references: [id])
}

model InventoryItem {
  id                     String              @id @default(cuid())
  propertyId             String
  zoneId                 String?
  category               InventoryCategory
  name                   String
  condition              InventoryCondition  @default(GOOD)
  description            String?
  brand                  String?
  model                  String?
  serialNumber           String?
  material               String?
  isFunctional           Boolean             @default(true)
  technicalDetails       Json?
  expectedLifespanMonths Int?
  lastInspectionDate     DateTime?
  createdAt              DateTime            @default(now())
  comments               String?
  quantity               Int                 @default(1)
  evidences              InventoryEvidence[]
  property               Property            @relation(fields: [propertyId], references: [id])
  Zone                   Zone?               @relation(fields: [zoneId], references: [id])
  tickets                Ticket[]
}

model InventoryTemplate {
  id          String                  @id @default(cuid())
  tenantId    String
  name        String
  description String?
  status      TemplateStatus          @default(ACTIVE)
  createdAt   DateTime                @default(now())
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       InventoryTemplateItem[]
  zones       Zone[]
}

model InventoryTemplateItem {
  id                String             @id @default(cuid())
  templateId        String?
  zoneId            String?
  name              String
  category          InventoryCategory
  material          String?
  description       String?
  InventoryTemplate InventoryTemplate? @relation(fields: [templateId], references: [id])
  Zone              Zone?              @relation(fields: [zoneId], references: [id])
}

model Invoice {
  id             String               @id @default(cuid())
  tenantId       String
  type           InvoiceType          @default(SALES_INVOICE)
  sequence       String               @unique
  issueDate      DateTime             @default(now())
  dueDate        DateTime?
  subtotal       Decimal              @default(0)
  taxAmount      Decimal              @default(0)
  total          Decimal              @default(0)
  thirdPartyId   String
  journalEntryId String?
  dianStatus     DianStatus           @default(DRAFT)
  cufe           String?
  qrCodeUrl      String?
  xmlResponse    String?
  createdAt      DateTime             @default(now())
  dianZipKey     String?
  journalEntry   JournalEntry?        @relation(fields: [journalEntryId], references: [id])
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thirdParty     AccountingThirdParty @relation(fields: [thirdPartyId], references: [id])
  InvoiceLine    InvoiceLine[]
}

model InvoiceLine {
  id            String      @id @default(cuid())
  invoiceId     String
  billingItemId String
  quantity      Decimal     @default(1)
  unitPrice     Decimal
  taxAmount     Decimal     @default(0)
  total         Decimal
  BillingItem   BillingItem @relation(fields: [billingItemId], references: [id])
  Invoice       Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id               String            @id @default(cuid())
  tenantId         String
  date             DateTime
  documentType     String
  documentNumber   String?
  description      String
  status           EntryStatus       @default(DRAFT)
  createdByUserId  String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  annullReason     String?
  annulledAt       DateTime?
  annulledByUserId String?
  /// Block C — audit trail post-creación. Nullable porque rows
  /// pre-Block-C no los tenían; el backfill script setea
  /// postedAt = createdAt y postedByUserId = createdByUserId como
  /// mejor aproximación para asientos ya POSTED.
  postedAt         DateTime?
  postedByUserId   String?
  Invoice          Invoice[]
  annulledBy       User?             @relation("JournalEntryAnnulledBy", fields: [annulledByUserId], references: [id])
  createdBy        User              @relation("JournalEntryCreatedBy", fields: [createdByUserId], references: [id])
  postedBy         User?             @relation("JournalEntryPostedBy", fields: [postedByUserId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines            TransactionLine[]

  @@unique([tenantId, documentType, documentNumber])
  @@index([tenantId, date])
  @@index([tenantId, status])
}

model MeterReading {
  id          String    @id @default(cuid())
  propertyId  String
  type        MeterType
  value       String
  photoUrl    String?
  readingDate DateTime  @default(now())
  property    Property  @relation(fields: [propertyId], references: [id])
}

model Property {
  id                         String                    @id @default(cuid())
  tenantId                   String
  parentPropertyId           String?
  propertyType               PropertyType
  title                      String
  description                String?
  address                    String
  city                       String
  department                 String
  country                    String
  latitude                   Float?
  longitude                  Float?
  areaM2                     Float?
  rooms                      Int?
  bathrooms                  Int?
  status                     PropertyStatus            @default(AVAILABLE)
  propertyCode               String?
  isVip                      Boolean                   @default(false)
  isActive                   Boolean                   @default(true)
  rentAmount                 Decimal?
  adminAmount                Decimal?
  taxAmount                  Decimal?
  managementName             String?
  managementNit              String?
  insuranceCompany           String?
  splatUrl                   String?
  attachments                Json?
  createdAt                  DateTime                  @default(now())
  accessToken                String?                   @unique
  workflowId                 String?
  managementEmail            String?
  managementPhone            String?
  visionAnalysis             Json?
  admonEmail                 String?
  admonName                  String?
  admonPhone                 String?
  admonPorteria              String?
  visionVideoUrl             Json?
  importedAt                 DateTime?
  sourceTag                  String?
  ContractDocument           ContractDocument[]
  ContractRequest            ContractRequest[]
  inventoryItems             InventoryItem[]
  meterReadings              MeterReading[]
  property                   Property?                 @relation("PropertyToProperty", fields: [parentPropertyId], references: [id])
  other_interestedProperties Property[]                @relation("PropertyToProperty")
  tenant                     Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow                   Workflow?                 @relation(fields: [workflowId], references: [id])
  accessItems                PropertyAccessItem[]
  assignments                PropertyAgentAssignment[]
  relations                  PropertyRelation[]
  tickets                    Ticket[]
  lines                      TransactionLine[]
  zones                      Zone[]
  Prospect                   Prospect[]                @relation("PropertyInterests")

  @@unique([tenantId, propertyCode])
  @@index([tenantId, status])
  @@index([tenantId, isActive])
}

model PropertyAccessItem {
  id          String     @id @default(cuid())
  propertyId  String
  type        AccessType
  description String
  quantity    Int        @default(1)
  photoUrl    String?
  property    Property   @relation(fields: [propertyId], references: [id])
}

model PropertyAgentAssignment {
  id         String   @id @default(cuid())
  propertyId String
  agentId    String
  assignedAt DateTime @default(now())
  agent      User     @relation(fields: [agentId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
}

model PropertyRelation {
  id                  String             @id @default(cuid())
  propertyId          String
  userId              String
  relationType        RelationType
  percentageOwnership Float?
  startDate           DateTime
  endDate             DateTime?
  status              RelationStatus     @default(ACTIVE)
  contractNumber      String?
  insuranceCompany    String?
  contractType        String?
  ContractDocument    ContractDocument[]
  property            Property           @relation(fields: [propertyId], references: [id])
  user                User               @relation(fields: [userId], references: [id])

  @@index([status, relationType])
}

model Prospect {
  id                   String                @id @default(cuid())
  tenantId             String
  firstName            String
  lastName             String?
  email                String?
  phone                String?
  whatsappId           String?               @unique
  status               ProspectStatus        @default(NEW)
  source               ProspectSource        @default(MANUAL)
  sentiment            SentimentAnalysis     @default(NEUTRAL)
  assignedAgentId      String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ContractRequest      ContractRequest[]
  assignedAgent        User?                 @relation(fields: [assignedAgentId], references: [id])
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  interactions         ProspectInteraction[]
  tasks                ProspectTask[]
  interestedProperties Property[]            @relation("PropertyInterests")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, updatedAt])
  @@index([tenantId, sentiment])
}

/// P0.1 — `tenantId` denormalized on the child table. Pre-P0.1 the row
/// only carried `prospectId`; any code path that wrote a ProspectInteraction
/// without joining through Prospect.tenantId (e.g. `addInteraction` in
/// crm.service.ts pre-Block-P0.2) could cross tenants. With this column
/// + FK + index, writes are tenant-scoped at the DB level and `@@index`
/// keeps the foreign-tenant scans cheap. Backfilled from
/// `Prospect.tenantId` in `backfill-tenant-id-children.ts`.
model ProspectInteraction {
  id         String             @id @default(cuid())
  prospectId String
  userId     String?
  channel    InteractionChannel
  message    String
  sentiment  SentimentAnalysis?
  createdAt  DateTime           @default(now())
  tenantId   String
  prospect   Prospect           @relation(fields: [prospectId], references: [id])
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User?              @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([prospectId])
}

/// P0.1 — `tenantId` denormalized. See ProspectInteraction note. Tasks
/// were already cascade-deleted with the parent prospect, but writes
/// pre-P0.1 trusted the controller layer; this column closes the
/// defense-in-depth gap. Backfilled from `Prospect.tenantId`.
model ProspectTask {
  id          String    @id @default(cuid())
  prospectId  String
  title       String
  description String?
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenantId    String
  prospect    Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId])
}

model Provider {
  id                 String                      @id @default(cuid())
  tenantId           String
  name               String
  nit                String?
  email              String?
  phone              String?
  address            String?
  specialty          ProviderSpecialty           @default(GENERAL)
  status             ProviderStatus              @default(ACTIVE)
  rating             Float?                      @default(5.0)
  contactName        String?
  contactLastName    String?
  contactId          String?
  contactPhone       String?
  photoUrl           String?
  legalArl           String?
  legalSst           Boolean                     @default(false)
  legalPolicyNumber  String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  thirdParty         AccountingThirdParty?
  tenant             Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  additionalContacts ProviderAdditionalContact[]
  tickets            Ticket[]
  technicians        User[]

  @@index([tenantId])
}

model ProviderAdditionalContact {
  id           String   @id @default(cuid())
  providerId   String
  firstName    String
  lastName     String
  governmentId String?
  phone        String?
  photoUrl     String?
  createdAt    DateTime @default(now())
  Provider     Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  permissions Json?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
}

model SubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  priceMonthly  Decimal
  maxProperties Int
  maxUsers      Int
  createdAt     DateTime @default(now())
  Tenant        Tenant[]
}

model Tenant {
  id                     String                 @id @default(cuid())
  name                   String
  nit                    String
  status                 TenantStatus           @default(ACTIVE)
  subscriptionPlanId     String
  createdAt              DateTime               @default(now())
  aiTone                 String?
  brandManualUrl         String?
  communicationTemplates Json?
  whatsappAccessToken    String?
  whatsappPhoneNumberId  String?                @unique
  whatsappProvider       String?                @default("meta")
  crmDefaultAssigneeEmail String?
  AccountingAccount      AccountingAccount[]
  AccountingThirdParty   AccountingThirdParty[]
  BillingItem            BillingItem[]
  BrandBrain             BrandBrain?
  ContractDocument       ContractDocument[]
  DianResolution         DianResolution[]
  DigitalCertificate     DigitalCertificate?
  fileAssets             FileAsset[]
  InventoryTemplate      InventoryTemplate[]
  Invoice                Invoice[]
  JournalEntry           JournalEntry[]
  interestedProperties   Property[]
  Prospect               Prospect[]
  prospectInteractions   ProspectInteraction[]
  prospectTasks          ProspectTask[]
  Provider               Provider[]
  Role                   Role[]
  subscriptionPlan       SubscriptionPlan       @relation(fields: [subscriptionPlanId], references: [id])
  tenantSubscription     TenantSubscription?
  tickets                Ticket[]
  ticketInteractions     TicketInteraction[]
  tokenUsageLogs         TokenUsageLog[]
  technicians            User[]
  Workflow               Workflow[]
}

model Ticket {
  id                   String              @id @default(cuid())
  tenantId             String
  propertyId           String
  reportedByUserId     String
  workflowId           String?
  currentStateId       String?
  reportedByUserPhone  String?
  assignedTechnicianId String?
  priority             TicketPriority      @default(MEDIUM)
  severity             TicketSeverity      @default(MEDIUM)
  title                String
  description          String
  aiDiagnosisSummary   String?
  estimatedCost        Decimal?
  ownerApproved        Boolean             @default(false)
  coordinates3d        Json?
  payerResponsible     PayerResponsible?   @default(AGENCY)
  createdAt            DateTime            @default(now())
  resolvedAt           DateTime?
  satisfactionStars    Int?
  satisfactionComment  String?
  assignedProviderId   String?
  closureReason        String?
  attachments          Json?
  clientSignature      String?
  inventoryItemId      String?
  shortId              String?
  parentTicketId       String?

  parentTicket         Ticket?             @relation("SubTickets", fields: [parentTicketId], references: [id])
  subTickets           Ticket[]            @relation("SubTickets")
  provider             Provider?           @relation(fields: [assignedProviderId], references: [id])
  assignedTechnician   User?               @relation("Ticket_assignedTechnicianIdToUser", fields: [assignedTechnicianId], references: [id])
  currentState         WorkflowState?      @relation(fields: [currentStateId], references: [id])
  InventoryItem        InventoryItem?      @relation(fields: [inventoryItemId], references: [id])
  property             Property            @relation(fields: [propertyId], references: [id])
  reportedByUser       User                @relation("Ticket_reportedByUserIdToUser", fields: [reportedByUserId], references: [id])
  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow             Workflow?           @relation(fields: [workflowId], references: [id])
  interactions         TicketInteraction[]
  stateLogs            TicketStateLog[]

  @@index([reportedByUserPhone])
  @@index([resolvedAt])
  @@index([tenantId])
  @@index([tenantId, assignedTechnicianId])
  @@index([tenantId, createdAt])
}

/// P0.1 — `tenantId` denormalized. See ProspectInteraction note.
/// TicketInteraction is the most-written child in the system (every
/// WhatsApp message creates one); the `@@index([ticketId])` is added
/// here too because the JOIN was already a seq scan pre-P0.1.
/// Backfilled from `Ticket.tenantId`.
model TicketInteraction {
  id                String             @id @default(cuid())
  ticketId          String
  userId            String?
  channel           InteractionChannel
  message           String
  sentimentAnalysis SentimentAnalysis?
  sentAt            DateTime           @default(now())
  tenantId          String
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ticket            Ticket             @relation(fields: [ticketId], references: [id])
  user              User?              @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([ticketId])
}

model TicketStateLog {
  id                String        @id @default(cuid())
  ticketId          String
  stateId           String
  startedAt         DateTime      @default(now())
  completedAt       DateTime?
  comment           String?
  completedByUserId String?
  attachments       Json?
  completedByUser   User?         @relation(fields: [completedByUserId], references: [id])
  state             WorkflowState @relation(fields: [stateId], references: [id])
  ticket            Ticket        @relation(fields: [ticketId], references: [id])
}

model TransactionLine {
  id             String                @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal               @default(0)
  credit         Decimal               @default(0)
  thirdPartyId   String?
  propertyId     String?
  description    String?
  account        AccountingAccount     @relation(fields: [accountId], references: [id])
  JournalEntry   JournalEntry          @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  property       Property?             @relation(fields: [propertyId], references: [id])
  thirdParty     AccountingThirdParty? @relation(fields: [thirdPartyId], references: [id])
}

model User {
  id                                               String                    @id @default(cuid())
  tenantId                                         String?
  email                                            String                    @unique
  passwordHash                                     String
  firstName                                        String
  lastName                                         String
  governmentId                                     String?
  role                                             UserRole                  @default(TENANT_USER)
  roleId                                           String?
  phone                                            String?
  whatsappId                                       String?
  photoUrl                                         String?
  isActive                                         Boolean                   @default(true)
  createdAt                                        DateTime                  @default(now())
  additionalContacts                               String?
  personType                                       String?
  isTaxDeclarant                                   Boolean                   @default(false)
  regimeType                                       String?
  applyReteIva                                     Boolean                   @default(false)
  applyReteFuente                                  Boolean                   @default(false)
  applyReteIca                                     Boolean                   @default(false)
  bankName                                         String?
  accountNumber                                    String?
  providerId                                       String?
  accountType                                      String?
  importedAt                                       DateTime?
  mustChangePassword                               Boolean                   @default(false)
  passwordChangedAt                                DateTime?
  sourceTag                                        String?
  thirdParty                                       AccountingThirdParty?
  ContractRequest                                  ContractRequest[]
  uploadedFiles                                    FileAsset[]
  JournalEntry_annulledBy                          JournalEntry[]            @relation("JournalEntryAnnulledBy")
  JournalEntry_createdBy                           JournalEntry[]            @relation("JournalEntryCreatedBy")
  JournalEntry_postedBy                            JournalEntry[]            @relation("JournalEntryPostedBy")
  assignments                                      PropertyAgentAssignment[]
  relations                                        PropertyRelation[]
  Prospect                                         Prospect[]
  interactions                                     ProspectInteraction[]
  RefreshTokens                                    RefreshToken[]
  Ticket_Ticket_assignedTechnicianIdToUser         Ticket[]                  @relation("Ticket_assignedTechnicianIdToUser")
  Ticket_Ticket_reportedByUserIdToUser             Ticket[]                  @relation("Ticket_reportedByUserIdToUser")
  ticketInteractions                               TicketInteraction[]
  stateLogs                                        TicketStateLog[]
  provider                                         Provider?                 @relation(fields: [providerId], references: [id])
  roleRef                                          Role?                     @relation(fields: [roleId], references: [id])
  tenant                                           Tenant?                   @relation(fields: [tenantId], references: [id])
  phoneContacts                                    UserPhoneContact[]
  WorkflowState_WorkflowState_assignedUserIdToUser WorkflowState[]           @relation("WorkflowState_assignedUserIdToUser")
  WorkflowState_RoleAssignments                    WorkflowState[]           @relation("RoleAssignments")

  @@index([phone])
  @@index([whatsappId])
  @@index([tenantId])
  @@index([tenantId, role])
}

/// *
///  * UserPhoneContact — additional WhatsApp / phone numbers authorized to
///  * speak on behalf of a User. Replaces the legacy CSV string in
///  * `User.additionalContacts` (which is preserved during the backfill
///  * window; cutover and column drop happen in Phase E.2).
///  * `verified=false` is the default for new rows written by the WA
///  * enrolment flow — verification arrives in Phase E.2 via an OTP sent
///  * to the user's primary `phone`. The unique constraint
///  * `@@unique([userId, phone])` closes the race where two concurrent
///  * webhooks both append the same number.
model UserPhoneContact {
  id         String    @id @default(cuid())
  userId     String
  phone      String
  verified   Boolean   @default(false)
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phone])
  @@index([phone])
}

model Workflow {
  id                   String          @id @default(cuid())
  tenantId             String
  name                 String
  description          String?
  createdAt            DateTime        @default(now())
  interestedProperties Property[]
  tickets              Ticket[]
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  states               WorkflowState[]

  @@index([tenantId])
}

model WorkflowState {
  id                   String           @id @default(cuid())
  workflowId           String
  name                 String
  order                Int
  assignedRole         UserRole?
  slaHours             Int?
  color                String?
  aiInstructions       String?
  assignedUserId       String?
  tickets              Ticket[]
  stateLogs            TicketStateLog[]
  responsible          User?            @relation("WorkflowState_assignedUserIdToUser", fields: [assignedUserId], references: [id])
  Workflow             Workflow         @relation(fields: [workflowId], references: [id])
  User_RoleAssignments User[]           @relation("RoleAssignments")
}

model Zone {
  id                String                  @id @default(cuid())
  propertyId        String?
  templateId        String?
  name              String
  type              ZoneType                @default(ZONAS_COMUNES)
  items             InventoryItem[]
  templateItems     InventoryTemplateItem[]
  property          Property?               @relation(fields: [propertyId], references: [id])
  InventoryTemplate InventoryTemplate?      @relation(fields: [templateId], references: [id])
}

model DataImportTemplate {
  id         String          @id @default(cuid())
  tenantId   String
  name       String
  categoryId String
  mapping    Json
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  logs       DataImportLog[]
}

model DataImportLog {
  id           String              @id @default(cuid())
  tenantId     String
  templateId   String?
  fileName     String
  sourceTag    String
  status       String
  recordsRead  Int                 @default(0)
  recordsSaved Int                 @default(0)
  errors       Json?
  createdAt    DateTime            @default(now())
  template     DataImportTemplate? @relation(fields: [templateId], references: [id])
}

model ContractDocument {
  id                 String            @id @default(cuid())
  tenantId           String
  propertyId         String
  propertyRelationId String?
  fileUrl            String
  status             DocumentStatus    @default(PENDING_AI)
  extractedData      Json?
  legalVerdict       Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  property           Property          @relation(fields: [propertyId], references: [id])
  propertyRelation   PropertyRelation? @relation(fields: [propertyRelationId], references: [id])
  tenant             Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId, propertyId])
}

model TenantSubscription {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  planType            String   @default("BASIC")
  monthlyTokenQuota   Int      @default(500000)
  billingCycleStart   DateTime @default(now())
  billingCycleEnd     DateTime
  softLimitThreshold  Float    @default(0.8)
  hardLimitEnabled    Boolean  @default(true)
  currentTokensInput  Int      @default(0)
  currentTokensOutput Int      @default(0)
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
}

model TokenUsageLog {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String?
  feature      String
  tokensInput  Int
  tokensOutput Int
  modelUsed    String   @default("gpt-4o-mini")
  costUsd      Float
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([usedAt, expiresAt])
}

model FileAsset {
  id           String   @id @default(cuid())
  tenantId     String
  filename     String   @unique
  originalName String
  mimeType     String
  sizeBytes    Int?
  uploadedById String?
  createdAt    DateTime @default(now())
  bucketKey    String?
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  @@index([tenantId])
}

