generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  
}

model AccountingAccount {
  id                      String @id @default(cuid())
  tenantId                String
  code                    String
  name                    String
  level                   AccountLevel
  nature                  AccountNature
  isActive                Boolean             @default(true)
  parentId                String?
  createdAt               DateTime            @default(now())
  updatedAt DateTime @updatedAt
  account       AccountingAccount?  @relation("AccountingAccountToAccountingAccount", fields: [parentId], references: [id])
  children AccountingAccount[] @relation("AccountingAccountToAccountingAccount")
  tenant Tenant @relation(fields: [tenantId], references: [id])
  BillingItem             BillingItem[]
  lines TransactionLine[]

  @@unique([tenantId, code])
}

model AccountingThirdParty {
  id               String @id @default(cuid())
  tenantId         String
  documentType     String
  documentNumber   String
  name             String
  email            String?
  phone            String?
  userId           String?           @unique
  providerId       String?           @unique
  taxLevelCode     String?
  ciiuCode         String?
  municipalityCode String?
  postalCode       String?
  createdAt        DateTime          @default(now())
  provider         Provider?         @relation(fields: [providerId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])
  user             User?             @relation(fields: [userId], references: [id])
  Invoice          Invoice[]
  lines TransactionLine[]

  @@unique([tenantId, documentType, documentNumber])
}

model BillingItem {
  id                String @id @default(cuid())
  tenantId          String
  code              String            @unique
  name              String
  basePrice         Decimal?          
  taxRate           Decimal           @default(0) 
  accountId         String
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  account AccountingAccount @relation(fields: [accountId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])
  InvoiceLine       InvoiceLine[]
}

model BrandBrain {
  id            String @id @default(cuid())
  tenantId      String   @unique
  tone          String   @default("PROFESSIONAL")
  policies      String?
  faq           Json?
  responseRules String?
  updatedAt DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ContractRequest {
  id               String @id @default(cuid())
  tenantId         String
  prospectId       String
  propertyId       String
  status           ContractStatus @default(PENDING_AI)
  formData         Json?
  aiDraft          String?
  approvedByUserId String?
  rejectionReason  String?
  createdAt        DateTime       @default(now())
  updatedAt DateTime @updatedAt
  user             User?          @relation(fields: [approvedByUserId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  prospect Prospect @relation(fields: [prospectId], references: [id])
}

model DianResolution {
  id               String @id @default(cuid())
  tenantId         String
  prefix           String
  resolutionNumber String
  startNumber      Int
  endNumber        Int
  currentNumber    Int
  validFrom        DateTime
  validTo          DateTime
  technicalKey     String?
  softwareId       String?
  softwarePin      String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model DigitalCertificate {
  id           String @id @default(cuid())
  tenantId     String    @unique
  filePath     String    @default("")
  fileBuffer   Bytes?
  passwordHash String
  validUntil   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model InventoryEvidence {
  id                 String @id @default(cuid())
  inventoryItemId    String
  evidenceType       EvidenceType
  url                String
  aiAnalysisStatus   AIAnalysisStatus    @default(PENDING)
  aiComparisonResult AIComparisonResult?
  captureDate        DateTime            @default(now())
  InventoryItem      InventoryItem       @relation(fields: [inventoryItemId], references: [id])
}

model InventoryItem {
  id                     String @id @default(cuid())
  propertyId             String
  zoneId                 String?
  category               InventoryCategory
  name                   String
  condition              InventoryCondition  @default(GOOD)
  description            String?
  brand                  String?
  model                  String?
  serialNumber           String?
  material               String?
  isFunctional           Boolean             @default(true)
  technicalDetails       Json?
  expectedLifespanMonths Int?
  lastInspectionDate     DateTime?
  createdAt              DateTime            @default(now())
  comments               String?
  quantity               Int                 @default(1)
  evidences InventoryEvidence[]
  property Property @relation(fields: [propertyId], references: [id])
  Zone                   Zone?               @relation(fields: [zoneId], references: [id])
  tickets Ticket[]
}

model InventoryTemplate {
  id                    String @id @default(cuid())
  tenantId              String
  name                  String
  description           String?
  status                TemplateStatus          @default(ACTIVE)
  createdAt             DateTime                @default(now())
  tenant Tenant @relation(fields: [tenantId], references: [id])
  items InventoryTemplateItem[]
  zones Zone[]
}

model InventoryTemplateItem {
  id                String @id @default(cuid())
  templateId        String?
  zoneId            String?
  name              String
  category          InventoryCategory
  material          String?
  description       String?
  InventoryTemplate InventoryTemplate? @relation(fields: [templateId], references: [id])
  Zone              Zone?              @relation(fields: [zoneId], references: [id])
}

model Invoice {
  id                   String @id @default(cuid())
  tenantId             String
  type                 InvoiceType          @default(SALES_INVOICE)
  sequence             String               @unique
  issueDate            DateTime             @default(now())
  dueDate              DateTime?
  subtotal             Decimal              @default(0) 
  taxAmount            Decimal              @default(0) 
  total                Decimal              @default(0) 
  thirdPartyId         String
  journalEntryId       String?
  dianStatus           DianStatus           @default(DRAFT)
  cufe                 String?
  qrCodeUrl            String?
  xmlResponse          String?
  createdAt            DateTime             @default(now())
  dianZipKey           String?
  journalEntry         JournalEntry?        @relation(fields: [journalEntryId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])
  thirdParty AccountingThirdParty @relation(fields: [thirdPartyId], references: [id])
  InvoiceLine          InvoiceLine[]
}

model InvoiceLine {
  id            String @id @default(cuid())
  invoiceId     String
  billingItemId String
  quantity      Decimal     @default(1) 
  unitPrice     Decimal     
  taxAmount     Decimal     @default(0) 
  total         Decimal     
  BillingItem   BillingItem @relation(fields: [billingItemId], references: [id])
  Invoice       Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id              String @id @default(cuid())
  tenantId        String
  date            DateTime
  documentType    String
  documentNumber  String?
  description     String
  status          EntryStatus       @default(DRAFT)
  createdByUserId String
  createdAt       DateTime          @default(now())
  updatedAt DateTime @updatedAt
  Invoice         Invoice[]
  createdBy User @relation(fields: [createdByUserId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])
  lines TransactionLine[]

  @@index([tenantId, date])
}

model MeterReading {
  id          String @id @default(cuid())
  propertyId  String
  type        MeterType
  value       String
  photoUrl    String?
  readingDate DateTime  @default(now())
  property Property @relation(fields: [propertyId], references: [id])
}

model Property {
  id                      String @id @default(cuid())
  tenantId                String
  parentPropertyId        String?
  propertyType            PropertyType
  title                   String
  description             String?
  address                 String
  city                    String
  department              String
  country                 String
  latitude                Float?
  longitude               Float?
  areaM2                  Float?
  rooms                   Int?
  bathrooms               Int?
  status                  PropertyStatus            @default(AVAILABLE)
  propertyCode            String?                   @unique
  isVip                   Boolean                   @default(false)
  isActive                Boolean                   @default(true)
  rentAmount              Decimal?
  adminAmount             Decimal?
  taxAmount               Decimal?
  managementName          String?
  managementNit           String?
  insuranceCompany        String?
  splatUrl                String?
  attachments             Json?
  createdAt               DateTime                  @default(now())
  accessToken             String?                   @unique
  workflowId              String?
  managementEmail         String?
  managementPhone         String?
  visionAnalysis          Json?
  admonEmail              String?
  admonName               String?
  admonPhone              String?
  admonPorteria           String?
  visionVideoUrl          Json?
  ContractRequest         ContractRequest[]
  inventoryItems InventoryItem[]
  meterReadings MeterReading[]
  property                Property?                 @relation("PropertyToProperty", fields: [parentPropertyId], references: [id])
  other_interestedProperties Property[]                @relation("PropertyToProperty")
  tenant Tenant @relation(fields: [tenantId], references: [id])
  workflow                Workflow?                 @relation(fields: [workflowId], references: [id])
  accessItems      PropertyAccessItem[]
  assignments PropertyAgentAssignment[]
  relations PropertyRelation[]
  tickets Ticket[]
  lines TransactionLine[]
  zones Zone[]
  Prospect                Prospect[]                @relation("PropertyInterests")
}

model PropertyAccessItem {
  id          String @id @default(cuid())
  propertyId  String
  type        AccessType
  description String
  quantity    Int        @default(1)
  photoUrl    String?
  property Property @relation(fields: [propertyId], references: [id])
}

model PropertyAgentAssignment {
  id         String @id @default(cuid())
  propertyId String
  agentId    String
  assignedAt DateTime @default(now())
  agent User @relation(fields: [agentId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
}

model PropertyRelation {
  id                  String @id @default(cuid())
  propertyId          String
  userId              String
  relationType        RelationType
  percentageOwnership Float?
  startDate           DateTime
  endDate             DateTime?
  status              RelationStatus @default(ACTIVE)
  contractNumber      String?
  insuranceCompany    String?
  contractType        String?
  property Property @relation(fields: [propertyId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model Prospect {
  id                  String @id @default(cuid())
  tenantId            String
  firstName           String
  lastName            String?
  email               String?
  phone               String?
  whatsappId          String?               @unique
  status              ProspectStatus        @default(NEW)
  source              ProspectSource        @default(MANUAL)
  sentiment           SentimentAnalysis     @default(NEUTRAL)
  assignedAgentId     String?
  createdAt           DateTime              @default(now())
  updatedAt DateTime @updatedAt
  ContractRequest     ContractRequest[]
  assignedAgent                User? @relation(fields: [assignedAgentId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])
  interactions ProspectInteraction[]
  tasks ProspectTask[]
  interestedProperties Property[]            @relation("PropertyInterests")
}

model ProspectInteraction {
  id         String @id @default(cuid())
  prospectId String
  userId     String?
  channel    InteractionChannel
  message    String
  sentiment  SentimentAnalysis?
  createdAt  DateTime           @default(now())
  prospect Prospect @relation(fields: [prospectId], references: [id])
  user       User?              @relation(fields: [userId], references: [id])
}

model ProspectTask {
  id          String @id @default(cuid())
  prospectId  String
  title       String
  description String?
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt DateTime @updatedAt
  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
}

model Provider {
  id                        String @id @default(cuid())
  tenantId                  String
  name                      String
  nit                       String?
  email                     String?
  phone                     String?
  address                   String?
  specialty                 ProviderSpecialty           @default(GENERAL)
  status                    ProviderStatus              @default(ACTIVE)
  rating                    Float?                      @default(5.0)
  contactName               String?
  contactLastName           String?
  contactId                 String?
  contactPhone              String?
  photoUrl                  String?
  legalArl                  String?
  legalSst                  Boolean                     @default(false)
  legalPolicyNumber         String?
  createdAt                 DateTime                    @default(now())
  updatedAt DateTime @updatedAt
  thirdParty      AccountingThirdParty?
  tenant Tenant @relation(fields: [tenantId], references: [id])
  additionalContacts ProviderAdditionalContact[]
  tickets Ticket[]
  technicians User[]
}

model ProviderAdditionalContact {
  id           String @id @default(cuid())
  providerId   String
  firstName    String
  lastName     String
  governmentId String?
  phone        String?
  photoUrl     String?
  createdAt    DateTime @default(now())
  Provider     Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model Role {
  id          String @id @default(cuid())
  tenantId    String
  name        String
  description String?
  permissions Json?
  createdAt   DateTime @default(now())
  tenant Tenant @relation(fields: [tenantId], references: [id])
  users User[]
}

model SubscriptionPlan {
  id            String @id @default(cuid())
  name          String
  priceMonthly  Decimal
  maxProperties Int
  maxUsers      Int
  createdAt     DateTime @default(now())
  Tenant        Tenant[]
}

model Tenant {
  id                     String @id @default(cuid())
  name                   String
  nit                    String
  status                 TenantStatus           @default(ACTIVE)
  subscriptionPlanId     String
  createdAt              DateTime               @default(now())
  aiTone                 String?
  brandManualUrl         String?
  whatsappPhoneNumberId  String?
  whatsappAccessToken    String?
  whatsappProvider       String?              @default("meta")
  communicationTemplates Json?
  AccountingAccount      AccountingAccount[]
  AccountingThirdParty   AccountingThirdParty[]
  BillingItem            BillingItem[]
  BrandBrain             BrandBrain?
  DianResolution         DianResolution[]
  DigitalCertificate     DigitalCertificate?
  InventoryTemplate      InventoryTemplate[]
  Invoice                Invoice[]
  JournalEntry           JournalEntry[]
  interestedProperties Property[]
  Prospect               Prospect[]
  Provider               Provider[]
  Role                   Role[]
  subscriptionPlan       SubscriptionPlan       @relation(fields: [subscriptionPlanId], references: [id])
  tickets Ticket[]
  technicians User[]
  Workflow               Workflow[]
}

model Ticket {
  id                                     String @id @default(cuid())
  tenantId                               String
  propertyId                             String
  reportedByUserId                       String
  workflowId                             String?
  currentStateId                         String?
  reportedByUserPhone                    String?
  assignedTechnicianId                   String?
  priority                               TicketPriority      @default(MEDIUM)
  severity                               TicketSeverity      @default(MEDIUM)
  title                                  String
  description                            String
  aiDiagnosisSummary                     String?
  estimatedCost                          Decimal?
  ownerApproved                          Boolean             @default(false)
  coordinates3d                          Json?
  payerResponsible                       PayerResponsible?   @default(AGENCY)
  createdAt                              DateTime            @default(now())
  resolvedAt                             DateTime?
  satisfactionStars                      Int?
  satisfactionComment                    String?
  assignedProviderId                     String?
  closureReason                          String?
  attachments                            Json?
  clientSignature                        String?
  inventoryItemId                        String?
  provider                               Provider?           @relation(fields: [assignedProviderId], references: [id])
  assignedTechnician User? @relation("Ticket_assignedTechnicianIdToUser", fields: [assignedTechnicianId], references: [id])
  currentState WorkflowState?      @relation(fields: [currentStateId], references: [id])
  InventoryItem                          InventoryItem?      @relation(fields: [inventoryItemId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  reportedByUser User @relation("Ticket_reportedByUserIdToUser", fields: [reportedByUserId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])
  workflow                               Workflow?           @relation(fields: [workflowId], references: [id])
  interactions TicketInteraction[]
  stateLogs TicketStateLog[]
}

model TicketInteraction {
  id                String @id @default(cuid())
  ticketId          String
  userId            String?
  channel           InteractionChannel
  message           String
  sentimentAnalysis SentimentAnalysis?
  sentAt            DateTime           @default(now())
  ticket Ticket @relation(fields: [ticketId], references: [id])
  user              User?              @relation(fields: [userId], references: [id])
}

model TicketStateLog {
  id                String @id @default(cuid())
  ticketId          String
  stateId           String
  startedAt         DateTime      @default(now())
  completedAt       DateTime?
  comment           String?
  completedByUserId String?
  attachments       Json?
  completedByUser              User? @relation(fields: [completedByUserId], references: [id])
  state WorkflowState @relation(fields: [stateId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id])
}

model TransactionLine {
  id                   String @id @default(cuid())
  journalEntryId       String
  accountId            String
  debit                Decimal               @default(0) 
  credit               Decimal               @default(0) 
  thirdPartyId         String?
  propertyId           String?
  description          String?
  account AccountingAccount @relation(fields: [accountId], references: [id])
  JournalEntry         JournalEntry          @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  property             Property?             @relation(fields: [propertyId], references: [id])
  thirdParty AccountingThirdParty? @relation(fields: [thirdPartyId], references: [id])
}

model User {
  id                                               String @id @default(cuid())
  tenantId                                         String?
  email                                            String                    @unique
  passwordHash                                     String
  firstName                                        String
  lastName                                         String
  governmentId                                     String?
  role                                             UserRole                  @default(TENANT_USER)
  roleId                                           String?
  phone                                            String?
  whatsappId                                       String?
  photoUrl                                         String?
  isActive                                         Boolean                   @default(true)
  createdAt                                        DateTime                  @default(now())
  additionalContacts                               String?
  personType                                       String?
  isTaxDeclarant                                   Boolean                   @default(false)
  regimeType                                       String?
  applyReteIva                                     Boolean                   @default(false)
  applyReteFuente                                  Boolean                   @default(false)
  applyReteIca                                     Boolean                   @default(false)
  bankName                                         String?
  accountNumber                                    String?
  providerId                                       String?
  accountType                                      String?
  thirdParty                             AccountingThirdParty?
  ContractRequest                                  ContractRequest[]
  JournalEntry                                     JournalEntry[]
  assignments PropertyAgentAssignment[]
  relations PropertyRelation[]
  Prospect                                         Prospect[]
  interactions ProspectInteraction[]
  Ticket_Ticket_assignedTechnicianIdToUser         Ticket[]                  @relation("Ticket_assignedTechnicianIdToUser")
  Ticket_Ticket_reportedByUserIdToUser             Ticket[]                  @relation("Ticket_reportedByUserIdToUser")
  ticketInteractions TicketInteraction[]
  stateLogs TicketStateLog[]
  provider                                         Provider?                 @relation(fields: [providerId], references: [id])
  roleRef Role? @relation(fields: [roleId], references: [id])
  tenant                                           Tenant?                   @relation(fields: [tenantId], references: [id])
  WorkflowState_WorkflowState_assignedUserIdToUser WorkflowState[]           @relation("WorkflowState_assignedUserIdToUser")
  WorkflowState_RoleAssignments                    WorkflowState[]           @relation("RoleAssignments")
}

model Workflow {
  id            String @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  createdAt     DateTime        @default(now())
  interestedProperties Property[]
  tickets Ticket[]
  tenant Tenant @relation(fields: [tenantId], references: [id])
  states WorkflowState[]
}

model WorkflowState {
  id                                      String @id @default(cuid())
  workflowId                              String
  name                                    String
  order                                   Int
  assignedRole                            UserRole?
  slaHours                                Int?
  color                                   String?
  aiInstructions                          String?
  assignedUserId                          String?
  tickets Ticket[]
  stateLogs TicketStateLog[]
  responsible User?            @relation("WorkflowState_assignedUserIdToUser", fields: [assignedUserId], references: [id])
  Workflow                                Workflow         @relation(fields: [workflowId], references: [id])
  User_RoleAssignments                    User[]           @relation("RoleAssignments")
}

model Zone {
  id                    String @id @default(cuid())
  propertyId            String?
  templateId            String?
  name                  String
  type                  ZoneType                @default(ZONAS_COMUNES)
  items InventoryItem[]
  templateItems InventoryTemplateItem[]
  property              Property?               @relation(fields: [propertyId], references: [id])
  InventoryTemplate     InventoryTemplate?      @relation(fields: [templateId], references: [id])
}

enum AIAnalysisStatus {
  PENDING
  ANALYZED
}

enum AIComparisonResult {
  SAME
  DETERIORATED
}

enum AccessType {
  KEY
  CONTROL
  CHIP
  SECURITY_CARD
}

enum AccountLevel {
  CLASE
  GRUPO
  CUENTA
  SUBCUENTA
  AUXILIAR
}

enum AccountNature {
  DEBIT
  CREDIT
}

enum ContractStatus {
  PENDING_AI
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum DianStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
  SENT_TO_DIAN
}

enum EntryStatus {
  DRAFT
  POSTED
  ANNULLED
}

enum EvidenceType {
  IMAGE
  VIDEO
  SPLAT_360
  VOICE_NOTE
}

enum InteractionChannel {
  WHATSAPP
  WEB
  SYSTEM_AI
}

enum InventoryCategory {
  KITCHEN
  BATHROOM
  LIVING_ROOM
  BEDROOM
  GENERAL
}

enum InventoryCondition {
  EXCELLENT
  GOOD
  REGULAR
  BAD
}

enum InvoiceType {
  SALES_INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum MeterType {
  ENERGY
  WATER
  GAS
}

enum PayerResponsible {
  OWNER
  TENANT
  AGENCY
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  UNDER_MAINTENANCE
  FOR_SALE
}

enum PropertyType {
  APARTMENT
  HOUSE
  BUILDING
  WAREHOUSE
  OFFICE
}

enum ProspectSource {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  MANUAL
  WEB
  RADAR_IA
}

enum ProspectStatus {
  NEW
  QUALIFIED
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum ProviderSpecialty {
  PLUMBING
  ELECTRICAL
  MASONRY
  CARPENTRY
  PAINTING
  AC_HEATING
  GENERAL
}

enum ProviderStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum RelationStatus {
  ACTIVE
  HISTORIC
}

enum RelationType {
  OWNER
  TENANT
}

enum SentimentAnalysis {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum TemplateStatus {
  ACTIVE
  INACTIVE
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UserRole {
  SUPERADMIN
  ADMIN_TENANT
  AGENT
  TECHNICIAN
  OWNER
  TENANT_USER
}

enum ZoneType {
  ZONAS_COMUNES
  ZONAS_PRIVADAS
  ZONAS_DE_SERVICIO
  EXTERIORES
}
