# DON ATENTO — Environment Variables Template
# ⚠️  Copy this file to .env and fill in real values.
# ⚠️  NEVER commit .env to Git. It is listed in .gitignore.
# 🔄  Run `openssl rand -hex 64` to generate JWT_SECRET.
# 🔄  Run `openssl rand -hex 32` to generate WHATSAPP_ENCRYPTION_KEY.

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase / Render PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ─── Postgres connection pool (pg.Pool) ───────────────────────────────────────
# Tuning of the node-postgres Pool that the PrismaPg adapter sits on. Defaults
# below are conservative for Render Free (512 MB instance). Bump for paid plans:
#
#   Tier                    PG_POOL_MAX    PG_POOL_MIN    notes
#   Render Free (512 MB)    10             2              <- defaults
#   Render Starter (2 GB)   25             2              recommended paid baseline
#   Render Standard (4 GB)  30+            5              tune with PRS load
#
# With Supabase PgBouncer in transaction mode the server-side connection budget
# is multiplexed; the ceiling here is really the RAM of the Node instance, not
# Postgres max_connections. Each pg pool conn takes ~3-5 MB of Node heap.
PG_POOL_MAX=10
# Minimum idle connections kept warm. >0 skips cold-start handshake on the first
# request after a quiet period; 0 saves RAM if the instance is tiny.
PG_POOL_MIN=2
# How long an idle connection sits before being closed.
PG_POOL_IDLE_TIMEOUT_MS=30000
# How long a request waits for a free connection before erroring. Keep small
# (fail-fast) so a degraded DB doesn't queue up a tide of waiters.
PG_POOL_CONNECT_TIMEOUT_MS=5000
# Server-side hard timeout on every query (Postgres `statement_timeout`). Kills
# runaway queries before they exhaust the pool — biggest noisy-neighbour
# mitigation. Override per-transaction with `SET LOCAL statement_timeout`
# inside legitimate long operations (XLSX import, batch report generation).
PG_STATEMENT_TIMEOUT_MS=30000

# ─── Authentication ────────────────────────────────────────────────────────────
# 128-char cryptographically random hex string — never use a placeholder
# Generate: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_128_CHAR_HEX
JWT_EXPIRES_IN="1h"

# ─── AI Integration ────────────────────────────────────────────────────────────
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY
OPENROUTER_API_KEY=

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=REPLACE_WITH_VERIFY_TOKEN
# REQUIRED. Meta App Secret — used to validate x-hub-signature-256 on every
# incoming webhook. Found at developers.facebook.com → Your App → Settings →
# Basic → "App Secret". Without this, /whatsapp/webhook returns 500.
WHATSAPP_APP_SECRET=REPLACE_WITH_META_APP_SECRET
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# REQUIRED for tenants that configure Meta WhatsApp credentials.
# 64-char hex (32 bytes / 256 bits) AES-GCM key used to encrypt
# Tenant.whatsappAccessToken at rest. Generate: openssl rand -hex 32
WHATSAPP_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX

# ─── Redis (WhatsApp conversation state) ──────────────────────────────────────
# For local development: redis://localhost:6379
# For production (Render Redis / Upstash): set via Render env vars
REDIS_URL=redis://localhost:6379

# ─── Localization ──────────────────────────────────────────────────────────────
DEFAULT_COUNTRY=CO
DEFAULT_CURRENCY=COP
IVA_RATE=0.19
TIMEZONE=America/Bogota

# ─── Supabase Storage ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=atento-media

# ─── DIAN credentials encryption ──────────────────────────────────────────────
# AES-256-GCM key used to encrypt softwarePin, technicalKey, and (future) the
# .p12 certificate passphrase at rest. 64-char hex string = 32 bytes / 256 bits.
# Generate: openssl rand -hex 32
DIAN_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX

# ─── DIAN SOAP transmission ───────────────────────────────────────────────────
# Set to literal "true" to activate real DIAN SOAP transmission. Any other
# value (including unset) keeps DianSoapService.sendSignedXmlToDian throwing
# NotImplementedException — there is no silent mock. Operator MUST also wire
# real ZIP packaging (e.g., via jszip) before enabling.
DIAN_TRANSMISSION_ENABLED=false
# Override the DIAN WSDL endpoint. Defaults to habilitación for tests.
# Production: https://vpfe.dian.gov.co/WcfDianCustomerServices.svc
DIAN_WSDL_URL=https://vpfe-hab.dian.gov.co/WcfDianCustomerServices.svc
